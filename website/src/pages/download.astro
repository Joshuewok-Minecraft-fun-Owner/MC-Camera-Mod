---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Download" description="Download the Minecraft Camera Mod for Java and Bedrock editions">
  <section class="download-section">
    <div class="container">
      <h1>Download Camera Mod</h1>
      <p class="intro-text">Choose your Minecraft edition and get the mod today.</p>

      <div class="download-grid">
        <!-- Java Edition -->
        <div class="download-card">
          <div class="edition-icon">☕</div>
          <h2>Java Edition</h2>
          <p class="edition-description">For Minecraft Java Edition players. Works with Fabric Loader.</p>
          
          <div class="version-info">
            <div class="info-item">
              <span class="label">Latest Version:</span>
              <span class="value">v2.0.0</span>
            </div>
            <div class="info-item">
              <span class="label">Compatible:</span>
              <span class="value">MC 1.20+</span>
            </div>
            <div class="info-item">
              <span class="label">Loader:</span>
              <span class="value">Fabric</span>
            </div>
            <div class="info-item">
              <span class="label">Size:</span>
              <span class="value">2.4 MB</span>
            </div>
          </div>

          <div class="download-features">
            <h4>Includes:</h4>
            <ul>
              <li>✓ Full camera system</li>
              <li>✓ 5 presets</li>
              <li>✓ Performance optimization</li>
              <li>✓ Privacy protection</li>
              <li>✓ Full source code access</li>
            </ul>
          </div>

          <div class="download-buttons">
            <a href="#" class="btn btn-primary">Download JAR</a>
            <a href="https://github.com" class="btn btn-secondary">GitHub</a>
          </div>
        </div>

        <!-- Bedrock Edition -->
        <div class="download-card">
          <div class="edition-icon">📱</div>
          <h2>Bedrock Edition</h2>
          <p class="edition-description">For Minecraft Bedrock Edition on Windows, mobile, and consoles.</p>
          
          <div class="version-info">
            <div class="info-item">
              <span class="label">Latest Version:</span>
              <span class="value">v1.8.0</span>
            </div>
            <div class="info-item">
              <span class="label">Compatible:</span>
              <span class="value">Bedrock 1.20+</span>
            </div>
            <div class="info-item">
              <span class="label">Type:</span>
              <span class="value">Addon Pack</span>
            </div>
            <div class="info-item">
              <span class="label">Size:</span>
              <span class="value">1.8 MB</span>
            </div>
          </div>

          <div class="download-features">
            <h4>Includes:</h4>
            <ul>
              <li>✓ Bedrock camera system</li>
              <li>✓ 5 presets</li>
              <li>✓ Optimized performance</li>
              <li>✓ Cross-device support</li>
              <li>✓ Easy installation</li>
            </ul>
          </div>

          <div class="download-buttons">
            <a href="#" class="btn btn-primary">Download .mcaddon</a>
            <a href="https://github.com" class="btn btn-secondary">GitHub</a>
          </div>
        </div>
      </div>

      <!-- Version History -->
      <section class="version-history">
        <h2>Version History</h2>
        
        <div class="release-item">
          <div class="release-header">
            <h3>v2.0.0</h3>
            <span class="release-date">May 29, 2026</span>
          </div>
          <div class="release-content">
            <h4>Java Edition</h4>
            <ul>
              <li>Added orbit preset</li>
              <li>Improved camera smoothing algorithm</li>
              <li>Fixed compatibility with Fabric 0.14+</li>
              <li>Performance optimizations</li>
            </ul>
          </div>
        </div>

        <div class="release-item">
          <div class="release-header">
            <h3>v1.8.0</h3>
            <span class="release-date">May 15, 2026</span>
          </div>
          <div class="release-content">
            <h4>Bedrock Edition</h4>
            <ul>
              <li>Initial release for Bedrock</li>
              <li>5 camera presets</li>
              <li>Full UI implementation</li>
              <li>Tested on Windows 10/11</li>
            </ul>
          </div>
        </div>

        <div class="release-item">
          <div class="release-header">
            <h3>v1.0.0</h3>
            <span class="release-date">April 1, 2026</span>
          </div>
          <div class="release-content">
            <h4>Java Edition</h4>
            <ul>
              <li>Initial release</li>
              <li>Basic camera controls</li>
              <li>3 presets (static, cinematic, orbit)</li>
              <li>Full mod documentation</li>
            </ul>
          </div>
        </div>

        <div class="more-versions">
          <a href="#">View all releases on GitHub →</a>
        </div>
      </section>

      <!-- System Requirements -->
      <section class="requirements">
        <h2>System Requirements</h2>
        
        <div class="requirements-grid">
          <div class="requirement-card">
            <h3>Java Edition</h3>
            <ul>
              <li>Minecraft Java Edition 1.20+</li>
              <li>Fabric Loader 0.14+</li>
              <li>Java Runtime 17+</li>
              <li>2GB RAM minimum</li>
              <li>Windows, macOS, or Linux</li>
            </ul>
          </div>

          <div class="requirement-card">
            <h3>Bedrock Edition</h3>
            <ul>
              <li>Minecraft Bedrock 1.20+</li>
              <li>Windows 10/11 or Mobile</li>
              <li>200MB free space</li>
              <li>1GB RAM minimum</li>
              <li>Compatible with Realms</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Troubleshooting Download -->
      <section class="download-help">
        <h2>Having trouble downloading?</h2>
        <div class="help-content">
          <details>
            <summary>Download button not working</summary>
            <p>Try right-clicking the download button and selecting "Save link as..." or use an alternative browser.</p>
          </details>

          <details>
            <summary>File is corrupted or incomplete</summary>
            <p>Delete the file and download again. If the problem persists, try downloading from our GitHub releases page.</p>
          </details>

          <details>
            <summary>Not sure which version to download</summary>
            <p>Use Java Edition if you have Minecraft Java Edition, or Bedrock if you have Minecraft from the Microsoft Store.</p>
          </details>

          <details>
            <summary>Installation issues</summary>
            <p>See our <a href="/installation">Installation Guide</a> for step-by-step instructions.</p>
          </details>
        </div>
      </section>

      <!-- Alternative Downloads -->
      <section class="alternative-downloads">
        <h2>Alternative Download Sources</h2>
        <p>If the direct download isn't working, you can also find the mod on:</p>
        <div class="source-links">
          <a href="#">🔗 GitHub Releases</a>
          <a href="#">🔗 CurseForge</a>
          <a href="#">🔗 Modrinth</a>
        </div>
      </section>
    </div>
  </section>

  <style>
    .download-section {
      padding: var(--spacing-3xl) var(--spacing-md);
    }

    .download-section h1 {
      text-align: center;
      margin-bottom: var(--spacing-lg);
    }

    .intro-text {
      text-align: center;
      font-size: 1.125rem;
      color: #64748b;
      margin-bottom: var(--spacing-3xl);
    }

    .download-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: var(--spacing-2xl);
      margin-bottom: var(--spacing-3xl);
    }

    .download-card {
      background: white;
      border: 2px solid var(--color-border);
      border-radius: 0.75rem;
      padding: var(--spacing-2xl);
      transition: all 0.3s ease;
    }

    .download-card:hover {
      border-color: var(--color-primary);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
      transform: translateY(-4px);
    }

    .edition-icon {
      font-size: 3.5rem;
      text-align: center;
      margin-bottom: var(--spacing-lg);
    }

    .download-card h2 {
      text-align: center;
      color: var(--color-primary);
      margin-bottom: var(--spacing-md);
    }

    .edition-description {
      text-align: center;
      color: #64748b;
      margin-bottom: var(--spacing-xl);
    }

    .version-info {
      background: #f8fafc;
      padding: var(--spacing-lg);
      border-radius: 0.5rem;
      margin-bottom: var(--spacing-xl);
    }

    .info-item {
      display: flex;
      justify-content: space-between;
      margin-bottom: var(--spacing-sm);
      font-size: 0.95rem;
    }

    .info-item .label {
      font-weight: 600;
      color: var(--color-dark);
    }

    .info-item .value {
      color: var(--color-secondary);
      font-weight: 600;
    }

    .download-features {
      margin-bottom: var(--spacing-xl);
    }

    .download-features h4 {
      margin-bottom: var(--spacing-md);
      color: var(--color-primary);
    }

    .download-features ul {
      list-style: none;
    }

    .download-features ul li {
      padding: var(--spacing-sm) 0;
      color: #475569;
    }

    .download-buttons {
      display: grid;
      gap: var(--spacing-md);
    }

    .btn {
      display: block;
      padding: var(--spacing-md) var(--spacing-lg);
      text-align: center;
      border-radius: 0.5rem;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      color: white;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(91, 33, 182, 0.3);
    }

    .btn-secondary {
      background: white;
      color: var(--color-primary);
      border: 2px solid var(--color-primary);
    }

    .btn-secondary:hover {
      background: var(--color-primary);
      color: white;
    }

    .version-history {
      margin: var(--spacing-3xl) 0;
    }

    .version-history h2 {
      margin-bottom: var(--spacing-2xl);
    }

    .release-item {
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      padding: var(--spacing-xl);
      margin-bottom: var(--spacing-lg);
    }

    .release-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--spacing-lg);
      padding-bottom: var(--spacing-lg);
      border-bottom: 2px solid var(--color-border);
    }

    .release-header h3 {
      color: var(--color-primary);
      margin: 0;
    }

    .release-date {
      color: #64748b;
      font-size: 0.9rem;
    }

    .release-content h4 {
      color: var(--color-dark);
      margin: var(--spacing-md) 0;
    }

    .release-content ul {
      list-style: none;
      margin-left: 0;
    }

    .release-content ul li {
      padding-left: var(--spacing-lg);
      position: relative;
      color: #475569;
    }

    .release-content ul li:before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--color-secondary);
    }

    .more-versions {
      text-align: center;
      margin-top: var(--spacing-xl);
    }

    .more-versions a {
      color: var(--color-primary);
      font-weight: 600;
    }

    .requirements {
      margin: var(--spacing-3xl) 0;
    }

    .requirements h2 {
      margin-bottom: var(--spacing-2xl);
    }

    .requirements-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-xl);
    }

    .requirement-card {
      background: white;
      border: 1px solid var(--color-border);
      padding: var(--spacing-xl);
      border-radius: 0.5rem;
    }

    .requirement-card h3 {
      color: var(--color-primary);
      margin-bottom: var(--spacing-lg);
    }

    .requirement-card ul {
      list-style: none;
    }

    .requirement-card ul li {
      padding: var(--spacing-sm) 0;
      color: #475569;
      padding-left: var(--spacing-lg);
      position: relative;
    }

    .requirement-card ul li:before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--color-secondary);
      font-weight: 700;
    }

    .download-help {
      background: #f8fafc;
      padding: var(--spacing-2xl);
      border-radius: 0.75rem;
      margin: var(--spacing-3xl) 0;
    }

    .download-help h2 {
      margin-bottom: var(--spacing-xl);
    }

    .help-content details {
      padding: var(--spacing-lg);
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      margin-bottom: var(--spacing-md);
      cursor: pointer;
    }

    .help-content summary {
      font-weight: 600;
      color: var(--color-primary);
      list-style: none;
    }

    .help-content summary::-webkit-details-marker {
      display: none;
    }

    .help-content summary:before {
      content: "▶ ";
      display: inline-block;
      margin-right: var(--spacing-sm);
      transition: transform 0.2s ease;
    }

    .help-content details[open] summary:before {
      transform: rotate(90deg);
    }

    .help-content details p {
      margin-top: var(--spacing-md);
      color: #475569;
    }

    .alternative-downloads {
      text-align: center;
      padding: var(--spacing-2xl);
      background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-primary) 100%);
      color: white;
      border-radius: 0.75rem;
    }

    .alternative-downloads h2 {
      color: white;
      margin-bottom: var(--spacing-lg);
    }

    .source-links {
      display: flex;
      gap: var(--spacing-lg);
      justify-content: center;
      flex-wrap: wrap;
      margin-top: var(--spacing-lg);
    }

    .source-links a {
      display: inline-block;
      padding: var(--spacing-md) var(--spacing-xl);
      background: white;
      color: var(--color-primary);
      border-radius: 0.375rem;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .source-links a:hover {
      background: #f1f5f9;
      transform: translateY(-2px);
    }

    @media (max-width: 768px) {
      .download-grid {
        grid-template-columns: 1fr;
      }

      .release-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .source-links {
        flex-direction: column;
      }

      .source-links a {
        width: 100%;
      }
    }
  </style>
</Layout>
