{
  "name": "Orbit",
  "description": "Orbiting camera that circles around the player for dynamic shots",
  "settings": {
    "distance": 6,
    "height": 2,
    "sideOffset": 0,
    "tilt": 25,
    "fov": 75,
    "smoothness": 0.9,
    "orbitDistance": 5,
    "orbitRotationSpeed": 2,
    "enableMotionSmoothing": true,
    "disableBob": true,
    "disableSway": true,
    "disableWobble": true
  }
}
